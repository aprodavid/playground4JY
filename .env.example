# Public Data API (Vercel routes do not use the key directly)
PUBLIC_DATA_BASE_URL=https://api.example.go.kr/endpoint
PUBLIC_DATA_SERVICE_KEY=your_public_data_service_key

# Firebase Admin SDK (Vercel / Next.js server)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your_project_id.iam.gserviceaccount.com
# Vercel에 입력할 때 줄바꿈은 \n 형태로 넣어도 서버에서 안전하게 복원됨
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Functions는 PUBLIC_DATA_SERVICE_KEY를 Secret Manager로 관리함.
# 배포 전: firebase functions:secrets:set PUBLIC_DATA_SERVICE_KEY
